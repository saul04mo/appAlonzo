rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════
    // Helper functions
    // ════════════════════════════════════════
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'administrador';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isOwnerOrAdmin(uid) {
      return isOwner(uid) || isAdmin();
    }

    // App/Web sales use sellerUid = 'APP' or 'WEB'
    function isAppOrWebSale() {
      return request.resource.data.sellerUid in ['APP', 'WEB'];
    }

    // ════════════════════════════════════════
    // 1. CONFIG (exchange rate, counters)
    // ════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // counter updated via transaction
    }

    // ════════════════════════════════════════
    // 2. PRODUCTS
    // ════════════════════════════════════════
    match /products/{productId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAuth(); // sellers update stock via sales
    }

    // ════════════════════════════════════════
    // 3. CLIENTS
    // ════════════════════════════════════════
    match /clients/{clientId} {
      // Anyone auth can read (needed for RIF lookup)
      allow read: if isAuth();
      // Users can create/update ONLY their own doc
      allow create: if isOwner(clientId) || isAdmin();
      allow update: if isOwner(clientId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════
    // 4. INVOICES
    // ════════════════════════════════════════
    match /invoices/{invoiceId} {
      // Auth users can read their own invoices or admins read all
      allow read: if isAuth();

      // Create: POS sellers (sellerUid == auth.uid) OR App/Web (sellerUid == 'APP'/'WEB')
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['numericId', 'items', 'total', 'date', 'status'])
        && request.resource.data.total >= 0
        && request.resource.data.items.size() > 0
        && (
          request.resource.data.sellerUid == request.auth.uid  // POS seller
          || isAppOrWebSale()                                   // App/Web sale
        );

      // Update: auth users (for status changes, payments, linking)
      allow update: if isAuth();

      // Never delete invoices
      allow delete: if false;
    }

    // ════════════════════════════════════════
    // 5. COUPONS
    // ════════════════════════════════════════
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      // Auth users can update (usedCount increment, usageByClient)
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedCount', 'usageByClient']);
    }

    // ════════════════════════════════════════
    // 6. PROMOTIONS
    // ════════════════════════════════════════
    match /promotions/{promotionId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 7. WISHLISTS
    // ════════════════════════════════════════
    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ════════════════════════════════════════
    // 8. USERS (POS staff)
    // ════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwnerOrAdmin(userId);
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 9. EMPLOYEES / PAYROLL
    // ════════════════════════════════════════
    match /employees/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /payrollPeriods/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /payrollReceipts/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /employeeIncidents/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // 10. BANNERS (home carousel)
    // ════════════════════════════════════════
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════
    // DENY EVERYTHING ELSE
    // ════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
