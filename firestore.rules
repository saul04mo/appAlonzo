rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════
    // FASE 1: Requiere autenticación en todo
    // Esto bloquea acceso anónimo sin romper el POS
    // ════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    // 1. CLIENTES — auth requerido, solo tu propio doc para crear
    match /clients/{clientId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // 2. PRODUCTOS — todos pueden leer, solo auth puede escribir
    match /products/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 3. FACTURAS — auth para todo, nunca borrar
    match /invoices/{invoiceId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.total is number;
      allow update: if isAuth();
      allow delete: if false;
    }

    // 4. CONFIGURACIÓN — todos leen, auth escribe
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 5. USUARIOS (POS staff)
    match /users/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // 6. GASTOS
    match /expenses/{document=**} {
      allow read, write: if isAuth();
    }

    // 7. CIERRES DE CAJA
    match /caja_cierres/{document=**} {
      allow read, write: if isAuth();
    }

    // 8. CALIFICACIONES
    match /order_ratings/{document=**} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // 9. MÉTODOS DE PAGO
    match /payment_methods/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // 10. CUPONES — auth lee, auth escribe (usedCount)
    match /coupons/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // 11. PROMOCIONES — todos leen, auth escribe
    match /promotions/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 12. FAVORITOS — solo el dueño
    match /wishlists/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // 13. BANNERS — todos leen, auth escribe
    match /banners/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 14. NÓMINA
    match /employees/{document=**} {
      allow read, write: if isAuth();
    }
    match /payrollPeriods/{document=**} {
      allow read, write: if isAuth();
    }
    match /payrollReceipts/{document=**} {
      allow read, write: if isAuth();
    }
    match /employeeIncidents/{document=**} {
      allow read, write: if isAuth();
    }

    // 15. HISTORIAL DE TASA DE CAMBIO
    match /exchangeRateHistory/{document=**} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // BLOQUEAR TODO LO DEMÁS
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
